#!/bin/bash

# User config for git
read -p "Enter username for git: " USERNAME
read -p "Enter email for git: " GIT_EMAIL
git config --global user.name "$USERNAME"
git config --global user.email "$GIT_EMAIL"

read -p "Would you like to set up an SSH key for GitHub? (y/n) " NEW_SSH
while [[ "$NEW_SSH" != "y" && "$NEW_SSH" != "n" ]]; do
	read -p "Invalid answer. Please try again (y/n) " NEW_SSH
done

if [[ $NEW_SSH == "y" ]]; then
	read -p "Setting up SSH key for GitHub. Enter key name: " KEY_NAME
	ssh-keygen -t ed25519 -C "$GIT_EMAIL" -f $HOME/.ssh/$KEY_NAME
	eval "$(ssh-agent -s)"
	ssh-add $HOME/.ssh/$KEY_NAME

	echo -e "Copy the public key below and add it to your github account."
	cat $HOME/.ssh/$KEY_NAME.pub
	read -p "Hit ENTER to continue." ENTER

	touch $HOME/.ssh/config
	echo "
    Host github.com
        HostName github.com
        User git
        IdentityFile ~/.ssh/$KEY_NAME
        IdentitiesOnly yes" >>$HOME/.ssh/config

	echo -e "Testing SSH key....."
	ssh -T git@github.com

	REMOTE_REPO=$(basename -s .git $(git config --get remote.origin.url))
	git remote set-url origin git@github.com:$USERNAME/$REMOTE_REPO.git
fi

# Skip password prompt for sudo commands
sudo su - <<END
printf "%%wheel ALL=(ALL) NOPASSWD: ALL\n" > /etc/sudoers.d/10-installer
END

# Install packages
echo "Installing packages..."
yay -Syu --noconfirm
yay -S neovim ranger stow postgresql rofi-greenclip ttf-nerd-fonts-symbols-mono nerd-fonts-jetbrains-mono-160 discord blueberry nodejs --noconfirm

# Change default editor
sudo sed -i "s/EDITOR=nano/EDITOR=nvim/" /etc/environment

# Change dunst notification location
sed -i "s/origin = bottom-right/origin = top-right/" $HOME/.config/dunst/dunstrc

# Postgresql config
sudo -iu postgres bash <<END
initdb -D /var/lib/postgres/data
END
sudo systemctl start postgresql
sudo systemctl enable postgresql

# Install lazyvim
mv $HOME/.config/nvim{,.bak}
git clone https://github.com/LazyVim/starter $HOME/.config/nvim

# Create dev directory
mkdir $HOME/dev/

# Use stow to create symlinks
stow --adopt */ -t ~
git restore .
reboot
