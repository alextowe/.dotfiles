#
# ~/.zshrc
# 

# Display current directory only
grml_prompt_token_default[path]='%B%F{cyan}%1~%f%b '

# Change prompt to a dollar sign
grml_prompt_token_default[percent]='%(#.#.$) '

# Change 
zstyle ':vcs_info:*' check-for-changes true
zstyle ':vcs_info:git:*' formats '%F{yellow}(%b%m)%f '
zstyle ':vcs_info:git:*' actionformats '%F{yellow}(%b%m|%a)%f '
zstyle ':vcs_info:git:*' nvcsformats '%F{green}(%b%m)%f '

# Disable the list prompt
zstyle ':completion:*' menu yes select

# Load syntax highlighting
if [ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
	source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# Load autosuggestions
if [ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

# Python virtualenv
#mkdir -p $WORKON_HOME
#source /usr/sbin/virtualenvwrapper.sh
